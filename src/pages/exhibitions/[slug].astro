---
import Layout from '../../layouts/Layout.astro';
import PhotoFigure from '../../components/PhotoFigure.astro';
import MotionReveal from '../../components/MotionReveal.astro';
import {
  getHallMap,
  getPublicExhibitions,
  resolveImage,
  type ExhibitionEntry,
} from '../../utils/content';

export async function getStaticPaths() {
  const exhibitions = await getPublicExhibitions();
  return exhibitions.map((exhibition) => ({
    params: { slug: exhibition.data.slug },
    props: { exhibition },
  }));
}

interface Props {
  exhibition: ExhibitionEntry;
}

const { exhibition } = Astro.props;
const hallMap = await getHallMap();
const hall = hallMap.get(exhibition.data.hallSlug);
---

<Layout title={exhibition.data.title} description={exhibition.data.intro}>
  <article class="exhibition">
    <header class="exhibition-header">
      <MotionReveal>
        <div class="meta-line">
          <span>{hall?.data.name ?? exhibition.data.hallSlug}</span>
          <span>{exhibition.data.location}</span>
          <span>{exhibition.data.dateLabel ?? exhibition.data.date}</span>
        </div>
        <h1>{exhibition.data.title}</h1>
        <p class="subtitle">{exhibition.data.subtitle}</p>
        <p class="intro">{exhibition.data.intro}</p>
      </MotionReveal>
    </header>

    <div class="photo-sequence" aria-label="展览照片序列">
      {
        exhibition.data.photos.map((photo, index) => (
          <MotionReveal>
            <PhotoFigure photo={photo} image={resolveImage(photo.src)} index={index} />
          </MotionReveal>
        ))
      }
    </div>
  </article>
</Layout>

<style>
  .exhibition {
    width: min(calc(100% - 2rem), var(--width-wide));
    margin-inline: auto;
  }

  .exhibition-header {
    width: min(100%, 880px);
    margin-inline: auto;
    padding: var(--space-8) 0;
  }

  h1 {
    margin: var(--space-3) 0 0;
    font-family: var(--font-serif);
    font-size: var(--step-4);
    font-weight: 400;
    line-height: 0.98;
  }

  .subtitle {
    margin: var(--space-3) 0 0;
    color: var(--color-ink-soft);
    font-size: var(--step-1);
  }

  .intro {
    max-width: 47rem;
    margin: var(--space-5) 0 0;
    color: var(--color-muted);
    font-size: var(--step-1);
    line-height: 1.92;
  }

  .photo-sequence {
    padding-bottom: var(--space-6);
  }

  @media (max-width: 680px) {
    .exhibition {
      width: min(calc(100% - 1.25rem), var(--width-wide));
    }
  }
</style>
