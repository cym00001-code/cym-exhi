---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import MotionReveal from '../components/MotionReveal.astro';
import siteCopy from '../data/site.json';
---

<Layout title={siteCopy.about.seoTitle} description={siteCopy.about.seoDescription}>
  <section class="page-section about-page">
    <MotionReveal>
      <SectionTitle label={siteCopy.about.sectionLabel} title={siteCopy.about.sectionTitle} />
    </MotionReveal>
    <div class="about-grid">
      <MotionReveal>
        <div class="about-copy">
          {siteCopy.about.body.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </MotionReveal>
      <MotionReveal>
        <aside class="about-note">
          <h2>{siteCopy.about.photographerTitle}</h2>
          <p>{siteCopy.about.photographer}</p>
          <h2>{siteCopy.about.gearTitle}</h2>
          <p>{siteCopy.about.gear}</p>
        </aside>
      </MotionReveal>
    </div>
  </section>
</Layout>

<style>
  .about-page {
    padding-top: var(--space-8);
  }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.38fr);
    gap: clamp(2rem, 6vw, 6rem);
    align-items: start;
  }

  .about-copy {
    max-width: 46rem;
    color: var(--color-muted);
    font-size: var(--step-1);
    line-height: 1.95;
  }

  .about-copy p {
    margin: 0 0 var(--space-4);
  }

  .about-note {
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-line);
    color: var(--color-muted);
  }

  .about-note h2 {
    margin: var(--space-4) 0 var(--space-2);
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .about-note h2:first-child {
    margin-top: 0;
  }

  .about-note p {
    margin: 0;
  }

  @media (max-width: 780px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
