---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { ExhibitionEntry, HallEntry } from '../utils/content';

interface Props {
  exhibition: ExhibitionEntry;
  hall?: HallEntry;
  image: ImageMetadata;
  compact?: boolean;
}

const { exhibition, hall, image, compact = false } = Astro.props;
---

<a class:list={['exhibition-card', { compact }]} href={`/exhibitions/${exhibition.data.slug}`}>
  <div class="cover">
    <Image
      src={image}
      alt={exhibition.data.photos[0]?.alt ?? exhibition.data.title}
      widths={[480, 720, 960, 1280]}
      sizes={compact ? '(max-width: 760px) 100vw, 30vw' : '(max-width: 860px) 100vw, 42vw'}
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="info">
    <div class="meta-line">
      {hall && <span>{hall.data.name}</span>}
      <span>{exhibition.data.location}</span>
      <span>{exhibition.data.dateLabel ?? exhibition.data.date}</span>
    </div>
    <h3>{exhibition.data.title}</h3>
    <p>{exhibition.data.subtitle}</p>
  </div>
</a>

<style>
  .exhibition-card {
    display: grid;
    grid-template-columns: minmax(260px, 0.78fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: end;
    padding: var(--space-5) 0;
    border-top: 1px solid var(--color-line);
  }

  .exhibition-card.compact {
    grid-template-columns: 1fr;
    gap: var(--space-3);
    padding: 0;
    border-top: 0;
  }

  .cover {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border: 1px solid var(--color-line);
    background: var(--color-stone-100);
  }

  .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.9) contrast(0.98);
    transition:
      transform 900ms var(--motion-ease),
      filter var(--motion-duration) var(--motion-ease);
  }

  .exhibition-card:hover .cover :global(img) {
    transform: scale(1.018);
    filter: saturate(1) contrast(1);
  }

  .info {
    display: grid;
    gap: var(--space-2);
  }

  h3 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--step-2);
    font-weight: 400;
    line-height: 1.18;
  }

  p {
    max-width: 34rem;
    margin: 0;
    color: var(--color-muted);
  }

  @media (max-width: 760px) {
    .exhibition-card {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>
