---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { ExhibitionPhoto } from '../utils/content';

interface Props {
  photo: ExhibitionPhoto;
  image: ImageMetadata;
  index: number;
}

const { photo, image, index } = Astro.props;
---

<figure class:list={['photo-figure', `orientation-${photo.orientation}`]}>
  <div class="photo-frame">
    <Image
      src={image}
      alt={photo.alt}
      widths={[720, 960, 1280, 1600, 2000]}
      sizes="(max-width: 760px) 100vw, 78vw"
      loading={index === 0 ? 'eager' : 'lazy'}
      decoding="async"
    />
  </div>
  <figcaption>
    <span>{String(index + 1).padStart(2, '0')}</span>
    <p>{photo.caption}</p>
    <small>{[photo.location, photo.date].filter(Boolean).join(' / ')}</small>
  </figcaption>
</figure>

<style>
  .photo-figure {
    display: grid;
    gap: var(--space-3);
    width: min(100%, 1080px);
    margin: 0 auto var(--space-8);
  }

  .orientation-portrait {
    width: min(100%, 760px);
  }

  .orientation-square {
    width: min(100%, 820px);
  }

  .photo-frame {
    overflow: hidden;
    border: 1px solid rgba(24, 21, 17, 0.16);
    background: var(--color-stone-100);
  }

  .orientation-landscape .photo-frame {
    aspect-ratio: 3 / 2;
  }

  .orientation-portrait .photo-frame {
    aspect-ratio: 3 / 4.3;
  }

  .orientation-square .photo-frame {
    aspect-ratio: 1 / 1;
  }

  .photo-frame :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  figcaption {
    display: grid;
    grid-template-columns: 3rem minmax(0, 1fr) auto;
    gap: var(--space-3);
    align-items: baseline;
    color: var(--color-muted);
  }

  figcaption span,
  figcaption small {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  figcaption p {
    margin: 0;
    color: var(--color-ink-soft);
    line-height: 1.7;
  }

  @media (max-width: 680px) {
    .photo-figure {
      margin-bottom: var(--space-7);
    }

    figcaption {
      grid-template-columns: 2.5rem minmax(0, 1fr);
    }

    figcaption small {
      grid-column: 2;
    }
  }
</style>
