---
import navigation from '../data/navigation.json';
import siteCopy from '../data/site.json';

const navItems = navigation.publicNav
  .filter(
    (item) =>
      item.enabled && !item.href.startsWith('/studio') && !item.href.startsWith('/curator-studio'),
  )
  .sort((a, b) => a.order - b.order);

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <a class="brand" href="/" aria-label={`${siteCopy.brand.englishTitle} home`}>
    <span class="brand-mark">Y</span>
    <span>
      <strong>{siteCopy.brand.englishTitle}</strong>
      <small>{siteCopy.brand.chineseSubtitle}</small>
    </span>
  </a>
  <nav class="public-nav" aria-label="Public exhibition navigation">
    {
      navItems.map((item) => {
        const active = currentPath === item.href || currentPath.startsWith(`${item.href}/`);
        return (
          <a href={item.href} aria-current={active ? 'page' : undefined}>
            {item.label}
          </a>
        );
      })
    }
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    width: min(calc(100% - 2rem), var(--width-wide));
    margin-inline: auto;
    padding: 1.05rem 0;
    backdrop-filter: blur(18px);
  }

  .site-header::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    content: '';
    background: linear-gradient(90deg, transparent, var(--color-line), transparent);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    min-width: 0;
  }

  .brand-mark {
    display: grid;
    flex: 0 0 2rem;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid var(--color-line-strong);
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: 1rem;
  }

  .brand strong,
  .brand small {
    display: block;
    white-space: nowrap;
  }

  .brand strong {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.2;
  }

  .brand small {
    color: var(--color-muted);
    font-size: 0.76rem;
    line-height: 1.3;
  }

  .public-nav {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.6vw, 2.6rem);
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .public-nav a {
    position: relative;
    padding-block: 0.25rem;
    transition: color var(--motion-duration) var(--motion-ease);
  }

  .public-nav a::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    content: '';
    background: currentColor;
    opacity: 0;
    transform: scaleX(0.4);
    transition:
      opacity var(--motion-duration) var(--motion-ease),
      transform var(--motion-duration) var(--motion-ease);
  }

  .public-nav a:hover,
  .public-nav a[aria-current='page'] {
    color: var(--color-ink);
  }

  .public-nav a:hover::after,
  .public-nav a[aria-current='page']::after {
    opacity: 1;
    transform: scaleX(1);
  }

  @media (max-width: 640px) {
    .site-header {
      position: relative;
      align-items: flex-start;
      flex-direction: column;
      width: min(calc(100% - 1.25rem), var(--width-wide));
      gap: 0.85rem;
      padding: 0.9rem 0;
    }

    .public-nav {
      width: 100%;
      gap: 1.35rem;
      overflow-x: auto;
      padding-bottom: 0.1rem;
      scrollbar-width: none;
    }

    .public-nav::-webkit-scrollbar {
      display: none;
    }
  }
</style>
