---
import siteCopy from '../data/site.json';
---

<section class="hero">
  <div class="hero-copy">
    <p class="museum-label">{siteCopy.brand.museumLabel}</p>
    <h1>{siteCopy.brand.englishTitle}</h1>
    <p class="subtitle">{siteCopy.brand.chineseSubtitle}</p>
    <p class="intro">{siteCopy.home.intro}</p>
    <p class="supplement">{siteCopy.home.supplement}</p>
    <div class="hero-actions">
      <a class="quiet-link" href="/halls">{siteCopy.home.primaryActionLabel}</a>
      <a class="quiet-link secondary" href="/archive">{siteCopy.home.secondaryActionLabel}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    width: min(calc(100% - 2rem), var(--width-page));
    min-height: min(34rem, calc(72svh - 4rem));
    margin-inline: auto;
    padding: var(--space-6) 0 var(--space-6);
    display: flex;
    align-items: center;
  }

  .hero-copy {
    max-width: 52rem;
  }

  .museum-label {
    margin: 0 0 var(--space-3);
    color: var(--color-blue-gray);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1 {
    max-width: 11ch;
    margin: 0;
    font-family: var(--font-serif);
    font-size: var(--step-4);
    font-weight: 400;
    line-height: 0.94;
  }

  .subtitle {
    margin: var(--space-3) 0 0;
    color: var(--color-ink-soft);
    font-size: var(--step-1);
  }

  .intro {
    max-width: 42rem;
    margin: var(--space-5) 0 0;
    color: var(--color-muted);
    font-size: var(--step-1);
    line-height: 1.9;
  }

  .supplement {
    max-width: 40rem;
    margin: var(--space-3) 0 0;
    color: var(--color-muted);
    font-size: var(--step--1);
    line-height: 1.85;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.1rem 2rem;
    margin-top: var(--space-5);
  }

  .secondary {
    color: var(--color-blue-gray);
  }

  @media (max-width: 860px) {
    .hero {
      width: min(calc(100% - 1.25rem), var(--width-wide));
      min-height: auto;
      padding: var(--space-5) 0 var(--space-6);
    }

    h1 {
      max-width: 12ch;
    }

    .intro {
      margin-top: var(--space-4);
      line-height: 1.82;
    }

    .hero-actions {
      gap: 0.9rem 1.35rem;
      margin-top: var(--space-4);
    }
  }
</style>
