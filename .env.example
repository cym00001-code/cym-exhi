# Public exhibition remains a static Astro site.
# Curator Studio uses server-only runtime variables. Never commit real values.

STUDIO_PATH=/curator-studio
STUDIO_API_BASE=/api/curator-studio
STUDIO_HOST=127.0.0.1
STUDIO_API_PORT=3000

# Prefer STUDIO_PASSWORD_HASH in production:
# node -e "console.log(require('crypto').createHash('sha256').update('your-password').digest('hex'))"
STUDIO_PASSWORD_HASH=sha256:replace_with_sha256_hash
STUDIO_SESSION_SECRET=replace_with_long_random_secret
STUDIO_SESSION_HOURS=8

# Server publishing mode. Local development can leave this disabled.
STUDIO_PUBLISH_MODE=release
STUDIO_AUTO_BUILD=1
STUDIO_RELEASES_DIR=/www/wwwroot/photo-exhibition-site/releases
STUDIO_CURRENT_LINK=/www/wwwroot/photo-exhibition-site/current
